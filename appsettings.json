{
  "Kestrel": {
    "Endpoints": {
      "Https": {
        "Url": "https://localhost:5250",
        "Protocols": "Http1AndHttp2AndHttp3"
      }
    }
  },
  "Database": {
    "AutoMigrate": true,
    "FailStartupOnMigrationError": false
  },
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Jwt": {
    "Issuer": "Erp.Api",
    "Audience": "Erp.Frontend",
    "SigningKey": "",
    "ExpirationMinutes": 120
  },
  "Cors": {
    "Origins": [
      "http://localhost:3000"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
