ASPNETCORE_ENVIRONMENT=Development
ConnectionStrings__DefaultConnection=Host=your-dev-postgres-host;Port=5432;Database=your_dev_database;Username=your_dev_user;Password=your_dev_password;SSL Mode=Require;Trust Server Certificate=true
Jwt__SigningKey=replace-with-a-long-dev-secret
Google__ClientId=your-dev-google-oauth-web-client-id.apps.googleusercontent.com
Redis__Configuration=redis://localhost:6379/0
Redis__InstanceName=erp:
