ASPNETCORE_ENVIRONMENT=Development
Database__AutoMigrate=true
Database__FailStartupOnMigrationError=false
ConnectionStrings__DefaultConnection=Host=your-postgres-host;Port=5432;Database=your_database;Username=your_user;Password=your_password;SSL Mode=Require;Trust Server Certificate=true
Jwt__Issuer=Erp.Api
Jwt__Audience=Erp.Frontend
Jwt__SigningKey=replace-with-a-long-random-secret
Jwt__ExpirationMinutes=120
Google__ClientId=your-google-oauth-web-client-id.apps.googleusercontent.com
Cors__Origins__0=http://localhost:3000
    
Redis__Configuration=rediss://:your-redis-password@your-redis-host:6379/0
Redis__InstanceName=erp:
